@model WebApplication1.Models.HomeIndexViewModel

@{
    ViewData["Title"] = "Panel de Control";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center my-4 p-3 bg-white rounded shadow-sm">
        <div>
            <h1 class="h2 text-dark m-0 fw-bold">Panel Administrativo</h1>
            <p class="text-muted m-0">Gestión global de inventario, clientes y operaciones financieras</p>
        </div>
        <div class="text-end text-muted small">
            <i class="bi bi-calendar3 me-1"></i> @DateTime.Now.ToString("dd MMMM yyyy")
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4 col-xl-2.4 col-lg-2">
            <div class="card border-0 shadow-sm bg-primary text-white h-100">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-white-50 text-uppercase mb-1 small fw-bold">Categorías</h6>
                        <h3 class="m-0 fw-bold">@Model.Categories.Count()</h3>
                    </div>
                    <i class="bi bi-tags fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2.4 col-lg-2">
            <div class="card border-0 shadow-sm bg-success text-white h-100">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-white-50 text-uppercase mb-1 small fw-bold">Productos</h6>
                        <h3 class="m-0 fw-bold">@Model.Products.Count()</h3>
                    </div>
                    <i class="bi bi-box-seam fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2.4 col-lg-2">
            <div class="card border-0 shadow-sm bg-info text-white h-100">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-white-50 text-uppercase mb-1 small fw-bold">Clientes</h6>
                        <h3 class="m-0 fw-bold">@Model.Clientes.Count()</h3>
                    </div>
                    <i class="bi bi-people fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2.4 col-lg-2">
            <div class="card border-0 shadow-sm bg-warning text-dark h-100">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-dark-50 text-uppercase mb-1 small fw-bold">Centros de Costo</h6>
                        <h3 class="m-0 fw-bold">@Model.CentrosCostos.Count()</h3>
                    </div>
                    <i class="bi bi-calculator fs-1 text-dark-50"></i>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4 col-xl-2.4 col-lg-4">
            <div class="card border-0 shadow-sm bg-dark text-white h-100">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-white-50 text-uppercase mb-1 small fw-bold">Total Ventas</h6>
                        <h3 class="m-0 fw-bold">@Model.Ventas.Sum(v => v.Total).ToString("C0")</h3>
                    </div>
                    <i class="bi bi-currency-dollar fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs custom-tabs mb-4 border-bottom-0" id="panelTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-content-btn nav-link active fw-bold px-4 py-2-5 rounded-top border-0 me-2" id="operaciones-tab" data-bs-toggle="tab" data-bs-target="#operaciones" type="button" role="tab" aria-controls="operaciones" aria-selected="true">
                <i class="bi bi-cart-check me-2"></i>Operaciones y Catálogo
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-content-btn nav-link fw-bold px-4 py-2-5 rounded-top border-0" id="maestros-tab" data-bs-toggle="tab" data-bs-target="#maestros" type="button" role="tab" aria-controls="maestros" aria-selected="false">
                <i class="bi bi-gear me-2"></i>Parámetros Generales
            </button>
        </li>
    </ul>

    <div class="tab-content bg-white p-4 rounded shadow-sm border" id="panelTabsContent">

        <div class="tab-pane fade show active" id="operaciones" role="tabpanel" aria-labelledby="operaciones-tab">
            <div class="row g-4">
                <div class="col-lg-7 border-end-lg">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="text-dark fw-bold m-0"><i class="bi bi-box-seam me-2 text-success"></i>Catálogo de Productos</h4>
                        <a asp-controller="Products" asp-action="Create" class="btn btn-success btn-sm px-3"><i class="bi bi-plus-circle me-1"></i>Nuevo Producto</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle border-top">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-muted small text-uppercase">Nombre</th>
                                    <th class="text-muted small text-uppercase text-end">Precio</th>
                                    <th class="text-muted small text-uppercase">Categoría</th>
                                    <th class="text-muted small text-uppercase text-center" style="width: 140px;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Products)
                                {
                                    <tr>
                                        <td class="fw-bold text-secondary">@item.Name</td>
                                        <td class="text-end fw-bold text-dark">@item.Price.ToString("C")</td>
                                        <td><span class="badge bg-light text-dark border px-2.5 py-1.5 rounded-pill">@(item.Category?.Name ?? "-")</span></td>
                                        <td>
                                            <div class="d-flex justify-content-center gap-1">
                                                <a asp-controller="Products" asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-outline-warning btn-sm border-0" title="Editar"><i class="bi bi-pencil-square"></i></a>
                                                <a asp-controller="Products" asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-outline-danger btn-sm border-0" title="Eliminar"><i class="bi bi-trash3"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="text-dark fw-bold m-0"><i class="bi bi-receipt me-2 text-dark"></i>Últimas Ventas</h4>
                        <a asp-controller="Ventas" asp-action="Create" class="btn btn-dark btn-sm px-3"><i class="bi bi-plus-circle me-1"></i>Registrar Venta</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle border-top">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-muted small text-uppercase">Fecha</th>
                                    <th class="text-muted small text-uppercase">Cliente</th>
                                    <th class="text-muted small text-uppercase text-end">Total</th>
                                    <th class="text-muted small text-uppercase text-center"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Ventas)
                                {
                                    <tr>
                                        <td class="text-secondary small">@item.Fecha.ToShortDateString()</td>
                                        <td class="small fw-semibold">@(item.Cliente?.Nombre ?? "-")</td>
                                        <td class="text-end fw-bold text-success">@item.Total.ToString("C")</td>
                                        <td>
                                            <div class="d-flex justify-content-center gap-1">
                                                <a asp-controller="Ventas" asp-action="Edit" asp-route-id="@item.VentaId" class="btn btn-outline-warning btn-sm border-0 p-1" title="Editar"><i class="bi bi-pencil"></i></a>
                                                <a asp-controller="Ventas" asp-action="Delete" asp-route-id="@item.VentaId" class="btn btn-outline-danger btn-sm border-0 p-1" title="Eliminar"><i class="bi bi-trash"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="maestros" role="tabpanel" aria-labelledby="maestros-tab">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="text-dark fw-bold m-0">Categorías</h5>
                        <a asp-controller="Categories" asp-action="Create" class="btn btn-outline-primary btn-sm px-2 py-0.5"><i class="bi bi-plus"></i></a>
                    </div>
                    <div class="table-responsive" style="max-height: 400px; overflow-y:auto;">
                        <table class="table table-hover align-middle border-top table-sm">
                            <tbody class="border-bottom">
                                @foreach (var item in Model.Categories)
                                {
                                    <tr>
                                        <td class="fw-semibold text-secondary py-2">@item.Name</td>
                                        <td class="text-end">
                                            <a asp-controller="Categories" asp-action="Edit" asp-route-id="@item.CategoryId" class="btn text-warning btn-sm p-1"><i class="bi bi-pencil"></i></a>
                                            <a asp-controller="Categories" asp-action="Delete" asp-route-id="@item.CategoryId" class="btn text-danger btn-sm p-1"><i class="bi bi-trash"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="col-md-4 border-start-md border-end-md">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="text-dark fw-bold m-0">Clientes</h5>
                        <a asp-controller="Clientes" asp-action="Create" class="btn btn-outline-primary btn-sm px-2 py-0.5"><i class="bi bi-plus"></i></a>
                    </div>
                    <div class="table-responsive" style="max-height: 400px; overflow-y:auto;">
                        <table class="table table-hover align-middle border-top table-sm">
                            <tbody class="border-bottom">
                                @foreach (var item in Model.Clientes)
                                {
                                    <tr>
                                        <td class="py-2">
                                            <div class="fw-semibold text-secondary">@item.Nombre</div>
                                            <small class="text-muted d-block" style="font-size: 0.75rem;">Doc: @item.Documento</small>
                                        </td>
                                        <td class="text-end">
                                            <a asp-controller="Clientes" asp-action="Edit" asp-route-id="@item.ClienteId" class="btn text-warning btn-sm p-1"><i class="bi bi-pencil"></i></a>
                                            <a asp-controller="Clientes" asp-action="Delete" asp-route-id="@item.ClienteId" class="btn text-danger btn-sm p-1"><i class="bi bi-trash"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="text-dark fw-bold m-0">Centros de Costo</h5>
                        <a asp-controller="CentroCostoes" asp-action="Create" class="btn btn-outline-primary btn-sm px-2 py-0.5"><i class="bi bi-plus"></i></a>
                    </div>
                    <div class="table-responsive" style="max-height: 400px; overflow-y:auto;">
                        <table class="table table-hover align-middle border-top table-sm">
                            <tbody class="border-bottom">
                                @foreach (var item in Model.CentrosCostos)
                                {
                                    <tr>
                                        <td class="py-2">
                                            <span class="badge bg-secondary-subtle text-secondary me-1">@item.Codigo</span>
                                            <span class="fw-semibold text-secondary">@item.Nombre</span>
                                        </td>
                                        <td class="text-end">
                                            <a asp-controller="CentroCostoes" asp-action="Edit" asp-route-id="@item.CentroCostoId" class="btn text-warning btn-sm p-1"><i class="bi bi-pencil"></i></a>
                                            <a asp-controller="CentroCostoes" asp-action="Delete" asp-route-id="@item.CentroCostoId" class="btn text-danger btn-sm p-1"><i class="bi bi-trash"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }
    .custom-tabs .nav-link {
        background-color: #e9ecef;
        color: #495057;
        border-bottom: 2px solid transparent;
        transition: all 0.2s ease;
    }
    .custom-tabs .nav-link.active {
        background-color: #ffffff !important;
        color: #0d6efd !important;
        position: relative;
    }
    .custom-tabs .nav-link.active::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        right: 0;
        height: 2px;
        background-color: #ffffff;
    }
    @@media (min-width: 992px) {
        .border-end-lg { border-end: 1px solid #dee2e6!important; padding-right: 1.5rem; }
        .border-start-md { border-start: 1px solid #dee2e6!important; padding-left: 1rem; }
        .border-end-md { border-end: 1px solid #dee2e6!important; padding-right: 1rem; }
    }
</style>