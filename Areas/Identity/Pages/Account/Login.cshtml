@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
}

@* --- INICIO DE SECCIÓN CENTRADA --- *@
<div class="row justify-content-center">
    <div class="col-md-12">
        <section>
            <form id="account" method="post">
                <h2 class="text-center">Iniciar sesión</h2>
                <hr />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                @* Comentado para ocultar el "Remember me":
                <div class="checkbox mb-3">
                    <label asp-for="Input.RememberMe" class="form-label">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>
                *@

                <div class="d-grid">
                    <button id="login-submit" type="submit" class="btn btn-lg btn-primary">Log in</button>
                </div>

                <div class="mt-3 text-center">
                    @* Comentado para ocultar:
                    <p>
                        <a id="forgot-password" asp-page="./ForgotPassword">¿Olvidaste tu contraseña?</a>
                    </p>
                    <p>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Registrar nuevo usuario</a>
                    </p>
                    *@
                </div>
            </form>
        </section>
    </div>
</div>
@* --- FIN DE SECCIÓN CENTRADA --- *@

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}